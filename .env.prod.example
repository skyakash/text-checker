# Production environment file. Copy to .env.prod and fill in real values.
# Never commit .env.prod to source control.

# --- Service ---
LOG_LEVEL=INFO
API_KEYS=change-me-to-a-real-secret-key

# --- Provider ---
OLLAMA_BASE_URL=http://ollama:11434/v1
DEFAULT_MODEL=qwen2.5:7b-instruct

# --- Cloud fallback (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Glossary + RAG ---
GLOSSARY_PATH=/app/data/glossary.json
RAG_STORE_PATH=/app/data/rag
RAG_COLLECTION_NAME=products
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_BASE_URL=
RAG_TOP_K=3
RAG_MIN_SCORE=0.50
RAG_SKIP_MODES=grammar

# --- Corporate proxy (if needed) ---
# HTTPS_PROXY=http://proxy.corp.example:8080
# HTTP_PROXY=http://proxy.corp.example:8080
# NO_PROXY=localhost,127.0.0.1,ollama,redis,service,prometheus
# SSL_CERT_FILE=/etc/ssl/certs/corp-ca.pem
