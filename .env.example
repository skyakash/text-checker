# Service
LOG_LEVEL=INFO
# Comma-separated API keys accepted by the service.
API_KEYS=dev-key-change-me

# Primary provider (Ollama by default; any OpenAI-compatible URL works).
OLLAMA_BASE_URL=http://localhost:11434/v1
DEFAULT_MODEL=qwen2.5:7b-instruct

# Cloud fallback (optional). Leave blank to disable.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cache (optional).
REDIS_URL=

# OpenTelemetry (optional).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Glossary store (JSON file). Terms are masked before reaching the LLM
# and restored in the output with their canonical case.
GLOSSARY_PATH=./data/glossary.json

# RAG (Chroma + Ollama embeddings). Auto-disables when the store is empty.
RAG_ENABLED=true
RAG_STORE_PATH=./data/rag
RAG_COLLECTION_NAME=products
RAG_EMBEDDING_MODEL=nomic-embed-text
# Defaults to OLLAMA_BASE_URL when blank.
RAG_EMBEDDING_BASE_URL=
RAG_TOP_K=3
# Cosine similarity floor. Calibrated for nomic-embed-text on small-to-medium
# corpora. Use `rag search <query>` to see your actual score distribution and
# adjust: dense corpora can usually raise this to 0.60-0.70 for stricter matches.
RAG_MIN_SCORE=0.50
# Modes that skip RAG entirely. Grammar is a character-level fix where
# product context only adds noise. Per-request use_rag=true overrides.
RAG_SKIP_MODES=grammar

# --- Corporate proxy and TLS interception ---
# httpx, uv, and ollama all read these. Uncomment and set as needed.
# NO_PROXY MUST include localhost AND every internal hostname (Ollama,
# compose service names) so internal traffic bypasses the proxy.
# HTTPS_PROXY=http://proxy.corp.example:8080
# HTTP_PROXY=http://proxy.corp.example:8080
# NO_PROXY=localhost,127.0.0.1,ollama,service,prometheus

# Path to a corporate CA bundle if the proxy does TLS interception.
# SSL_CERT_FILE=/etc/ssl/certs/corp-ca.pem
